# ────────────────────────────────────────────────────────────────────
# .env.example — Copia este archivo a .env y completa los valores
# NUNCA hagas commit de tu .env real al repositorio
# ────────────────────────────────────────────────────────────────────

# ── App ─────────────────────────────────────────────────
APP_NAME="ApoYo FES Acatlán"
ENVIRONMENT=development          # development | staging | production
DEBUG=true

# ── Seguridad — genera valores únicos con: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=GENERA_UN_VALOR_ALEATORIO_AQUI
JWT_SECRET_KEY=GENERA_OTRO_VALOR_ALEATORIO_AQUI

# ── Base de datos ────────────────────────────────────────
# PostgreSQL (producción)
DATABASE_URL=postgresql+asyncpg://apoyofes:TU_PASSWORD@localhost:5432/apoyofes_db
# SQLite (desarrollo rápido — descomenta y comenta la línea de arriba)
# DATABASE_URL=sqlite+aiosqlite:///./apoyofes.db

# ── JWT ──────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth ─────────────────────────────────────────
GOOGLE_CLIENT_ID=TU_CLIENT_ID.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=TU_CLIENT_SECRET
GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/google/callback
# Descomenta en producción para forzar correos @comunidad.unam.mx
# ALLOWED_EMAIL_DOMAIN=comunidad.unam.mx

# ── Email ────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-correo@gmail.com
SMTP_PASSWORD=tu-app-password
EMAIL_FROM=apoyofes@unam.mx
EMAIL_FROM_NAME=ApoYo FES Acatlán
ADMIN_ALERT_EMAIL=admin@fes.unam.mx

# ── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Rate limiting ────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ── IA (Anthropic) ───────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXX
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ── CORS ─────────────────────────────────────────────────
# En producción cambia a tu dominio real
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8000"]
